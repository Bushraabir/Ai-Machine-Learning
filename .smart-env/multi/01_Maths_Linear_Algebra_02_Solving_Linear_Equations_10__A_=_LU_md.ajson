rix} 1 & 0 \\ -\\ell & I \\end{pmatrix} \\begin{pmatrix} a_{11} & a_{12}^T \\ a_{21} & A_{22} \\end{pmatrix}#Worked Example: $3 \\times 3$ Full Elimination":[107,134],"#$$ \\begin{pmatrix} 1 & 0 \\ -\\ell & I \\end{pmatrix} \\begin{pmatrix} a_{11} & a_{12}^T \\ a_{21} & A_{22} \\end{pmatrix}#Worked Example: $3 \\times 3$ Full Elimination#{1}":[109,134],"#$$ \\begin{pmatrix} 1 & 0 & 0 \\ 2 & 1 & 0 \\ 4 & 3 & 1 \\end{pmatrix} \\begin{pmatrix} 2 & 1 & 1 \\ 0 & 1 & 1 \\ 0 & 0 & 2 \\end{pmatrix}":[135,136],"#\\begin{pmatrix} 1 \\cdot 2 & 1 \\cdot 1 & 1 \\cdot 1 \\ 2 \\cdot 2 + 0 & 2 \\cdot 1 + 1 & 2 \\cdot 1 + 1 \\ 4 \\cdot 2 + 0 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 2 \\end{pmatrix}":[137,158],"#\\begin{pmatrix} 1 \\cdot 2 & 1 \\cdot 1 & 1 \\cdot 1 \\ 2 \\cdot 2 + 0 & 2 \\cdot 1 + 1 & 2 \\cdot 1 + 1 \\ 4 \\cdot 2 + 0 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 2 \\end{pmatrix}#{1}":[139,144],"#\\begin{pmatrix} 1 \\cdot 2 & 1 \\cdot 1 & 1 \\cdot 1 \\ 2 \\cdot 2 + 0 & 2 \\cdot 1 + 1 & 2 \\cdot 1 + 1 \\ 4 \\cdot 2 + 0 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 2 \\end{pmatrix}#Using $A = LU$ to Solve $Ax = b$":[145,158],"#\\begin{pmatrix} 1 \\cdot 2 & 1 \\cdot 1 & 1 \\cdot 1 \\ 2 \\cdot 2 + 0 & 2 \\cdot 1 + 1 & 2 \\cdot 1 + 1 \\ 4 \\cdot 2 + 0 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 0 & 4 \\cdot 1 + 3 \\cdot 1 + 2 \\end{pmatrix}#Using $A = LU$ to Solve $Ax = b$#{1}":[147,158],"#$$ \\begin{pmatrix} 1 & 0 & 0 \\ 2 & 1 & 0 \\ 4 & 3 & 1 \\end{pmatrix} \\begin{pmatrix} c_1 \\ c_2 \\ c_3 \\end{pmatrix}":[159,166],"#$$ \\begin{pmatrix} 1 & 0 & 0 \\ 2 & 1 & 0 \\ 4 & 3 & 1 \\end{pmatrix} \\begin{pmatrix} c_1 \\ c_2 \\ c_3 \\end{pmatrix}#{1}":[161,166],"#$$ \\begin{pmatrix} 2 & 1 & 1 \\ 0 & 1 & 1 \\ 0 & 0 & 2 \\end{pmatrix} \\begin{pmatrix} x_1 \\ x_2 \\ x_3 \\end{pmatrix}":[167,302],"#$$ \\begin{pmatrix} 2 & 1 & 1 \\ 0 & 1 & 1 \\ 0 & 0 & 2 \\end{pmatrix} \\begin{pmatrix} x_1 \\ x_2 \\ x_3 \\end{pmatrix}#{1}":[169,176],"#$$ \\begi