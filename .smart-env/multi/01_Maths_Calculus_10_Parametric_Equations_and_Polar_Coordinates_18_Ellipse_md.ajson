
"smart_sources:01.Maths/Calculus/10.Parametric Equations and Polar Coordinates/18.Ellipse.md": {"path":"01.Maths/Calculus/10.Parametric Equations and Polar Coordinates/18.Ellipse.md","last_embed":{"hash":"cgtaei","at":1776558783739},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03751085,0.00308516,0.04893697,0.00833393,-0.09664957,0.0075433,0.06256137,0.06230158,0.01442196,-0.00489993,0.0149038,-0.08808222,0.04306665,0.01493315,-0.01511908,-0.00015851,-0.02305406,0.07999611,-0.13002869,0.00935869,0.21855234,-0.03832731,-0.01996663,-0.00220929,0.08176457,0.1314362,-0.02318339,-0.04871372,-0.03497179,-0.21641715,0.04927999,0.01997729,0.03355816,-0.02265043,0.00128551,-0.01388452,0.00940116,0.03697937,-0.05248317,0.05777694,0.0089919,0.04641228,0.00093069,-0.05968698,0.00604672,-0.05752235,-0.05281186,0.06063816,-0.02402117,-0.05739596,-0.0121083,-0.01959251,0.03966489,-0.0127416,0.00379621,0.04109188,0.03604138,0.03663049,0.01160464,0.04175056,0.05682326,-0.02303854,-0.20263219,0.11352854,-0.00498943,0.05685188,0.00745781,-0.04430401,-0.00834181,0.01935138,-0.00550132,0.01811538,-0.03626607,-0.00488607,-0.00537299,-0.03678706,-0.01337904,-0.04262239,-0.05091657,-0.02909401,0.00428815,-0.02015104,-0.03649983,0.0056933,0.03375605,0.01172352,0.05886776,-0.05381157,0.07776425,0.01687631,-0.01104234,-0.0251104,-0.09890354,-0.00957141,0.03202484,-0.03669536,0.034406,0.04530837,-0.01033829,0.0946205,-0.015109,0.0319713,0.05434486,0.03229814,0.01900218,-0.051983,-0.02022767,-0.05637157,-0.0270745,-0.02550884,-0.02059739,-0.03378999,-0.00144386,-0.05137401,-0.0602657,-0.06404267,0.00529239,0.01777347,0.01265508,-0.01147856,-0.00806919,0.09384207,-0.01341342,0.00893198,0.05074477,-0.01066294,-0.00284268,0.02583262,0.02948861,0.05589001,0.03800467,0.03201537,0.0172028,-0.00631538,-0.03356197,0.05890338,0.03383746,0.01396705,-0.01399483,0.00777733,-0.03248899,-0.04192757,0.00237766,-0.00262851,0.05903134,0.11504071,-0.04959704,-0.01666507,-0.04026708,0.01629558,0.00246695,-0.